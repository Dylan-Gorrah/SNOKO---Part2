<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Categories"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Add Category Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etCategoryName"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="New category name"
            android:textColor="#FFFFFF"
            android:textColorHint="#474747"
            android:background="@drawable/input_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnAddCategory"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Add"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D6415A" />
    </LinearLayout>

    <!-- Colour Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a colour:"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgColours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbRed"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:button="@null"
            android:background="@drawable/bg_colour_red"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbBlue"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:button="@null"
            android:background="@drawable/bg_colour_blue" />

        <RadioButton
            android:id="@+id/rbPurple"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:button="@null"
            android:background="@drawable/bg_colour_purple" />

        <RadioButton
            android:id="@+id/rbOrange"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:button="@null"
            android:background="@drawable/bg_colour_orange" />

        <RadioButton
            android:id="@+id/rbGreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:button="@null"
            android:background="@drawable/bg_colour_green" />

        <RadioButton
            android:id="@+id/rbGray"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:button="@null"
            android:background="@drawable/bg_colour_gray" />
    </RadioGroup>

    <!-- Categories List -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Categories:"
        android:textColor="#8E8E93"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never" />

</LinearLayout>
